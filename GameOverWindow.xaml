<Window x:Class="AirlineEmpire.Views.GameOverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游戏结束"
        Width="700" Height="620"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

  <Border Background="{StaticResource BgDeepBrush}"
          BorderBrush="#FF1C2E45" BorderThickness="1"
          CornerRadius="12"
          MouseLeftButtonDown="OnDrag">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- 标题栏 -->
      <Border Grid.Row="0" Background="#FF080F1A"
              CornerRadius="12,12,0,0"
              BorderBrush="#FF1C2E45" BorderThickness="0,0,0,1">
        <Grid>
          <TextBlock Text="游戏结算" FontSize="14" FontWeight="Bold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     FontFamily="Microsoft YaHei"
                     VerticalAlignment="Center" Margin="16,0"/>
          <Button Content="✕" Style="{StaticResource BtnRed}"
                  Width="30" Height="26" HorizontalAlignment="Right"
                  Margin="0,0,8,0" Click="OnClose"/>
        </Grid>
      </Border>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>

        <!-- 左：结算数据 -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="20">
          <StackPanel>
            <!-- 状态标题 -->
            <TextBlock x:Name="TxtStatus" FontSize="36" FontWeight="Bold"
                       FontFamily="Microsoft YaHei"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtReason" FontSize="13"
                       Foreground="{StaticResource TextDimBrush}"
                       FontFamily="Microsoft YaHei"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- 核心数据卡片 -->
            <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                  <TextBlock Text="最终资金" Style="{StaticResource SectionHeader}"
                             HorizontalAlignment="Center"/>
                  <TextBlock x:Name="TxtFunds" Style="{StaticResource HudNumber}"
                             FontSize="20" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                  <TextBlock Text="净利润" Style="{StaticResource SectionHeader}"
                             HorizontalAlignment="Center"/>
                  <TextBlock x:Name="TxtProfit" Style="{StaticResource HudNumber}"
                             FontSize="20" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                  <TextBlock Text="总起降" Style="{StaticResource SectionHeader}"
                             HorizontalAlignment="Center"/>
                  <TextBlock x:Name="TxtOps" Style="{StaticResource HudNumber}"
                             FontSize="20" HorizontalAlignment="Center"/>
                </StackPanel>
              </Grid>
            </Border>

            <!-- 机场明细 -->
            <TextBlock Text="机场明细" Style="{StaticResource SectionHeader}"/>
            <Border Style="{StaticResource PanelCard}" Margin="0,0,0,12">
              <ItemsControl x:Name="AirportList">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,4">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{Binding Code}"
                                 FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                 Foreground="{StaticResource AccentBlueBrush}"/>
                      <TextBlock Grid.Column="1" Text="{Binding Name}"
                                 FontSize="11" Foreground="{StaticResource TextDimBrush}"
                                 VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="2" FontSize="11" HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                        <Run Text="Lv" Foreground="{StaticResource TextDimBrush}"/>
                        <Run Text="{Binding Level}"
                             Foreground="{StaticResource AccentAmberBrush}"/>
                      </TextBlock>
                      <TextBlock Grid.Column="3" FontSize="11"
                                 HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Run Text="{Binding CurrentPassengers}"
                             Foreground="{StaticResource AccentGreenBrush}"/>
                        <Run Text="/" Foreground="{StaticResource TextDimBrush}"/>
                        <Run Text="{Binding MaxCapacity}"
                             Foreground="{StaticResource TextDimBrush}"/>
                      </TextBlock>
                      <TextBlock Grid.Column="4" FontSize="11"
                                 HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Text="{Binding TotalDeparted,StringFormat='出发{0}人'}"
                                 Foreground="{StaticResource TextDimBrush}"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>

            <!-- 导出按钮 -->
            <TextBlock Text="导出数据" Style="{StaticResource SectionHeader}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <Button Content="📊 导出 Excel" Style="{StaticResource BtnBlue}"
                      Margin="0,0,8,0" Click="OnExportExcel"/>
              <Button Content="📄 导出 CSV"   Style="{StaticResource BtnGhost}"
                      Margin="0,0,8,0" Click="OnExportCsv"/>
              <Button Content="☁ 上传排行榜" Style="{StaticResource BtnGreen}"
                      Click="OnUploadLeaderboard"/>
            </StackPanel>
            <TextBlock x:Name="TxtExportStatus" FontSize="11"
                       Foreground="{StaticResource AccentAmberBrush}"
                       FontFamily="Microsoft YaHei" Margin="0,4,0,0"/>
          </StackPanel>
        </ScrollViewer>

        <!-- 右：全服排行榜 -->
        <Border Grid.Column="1" Background="{StaticResource BgPanelBrush}"
                BorderBrush="#FF1C2E45" BorderThickness="1,0,0,0">
          <StackPanel Margin="12">
            <TextBlock Text="全服排行榜" Style="{StaticResource SectionHeader}"/>
            <TextBlock Text="按净利润排名" FontSize="10"
                       Foreground="{StaticResource TextDimBrush}"
                       Margin="0,0,0,10"/>
            <ItemsControl x:Name="LeaderboardList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="#FF1C2E45" BorderThickness="0,0,0,1" Padding="0,6">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0"
                                 Text="{Binding Rank, StringFormat='#{0}'}"
                                 Foreground="{StaticResource TextDimBrush}"
                                 FontFamily="Consolas" FontSize="11"/>
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding PlayerName}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding CreatedAt}"
                                   Foreground="{StaticResource TextDimBrush}"
                                   FontSize="10"/>
                      </StackPanel>
                      <TextBlock Grid.Column="2"
                                 Text="{Binding NetProfit, StringFormat='¥{0:N0}'}"
                                 Foreground="{StaticResource AccentGreenBrush}"
                                 FontFamily="Consolas" FontSize="12"
                                 VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="刷新" Style="{StaticResource BtnGhost}"
                    Margin="0,10,0,0" Click="OnRefreshLeaderboard"/>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Border>
</Window>
