<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ══ COLORS ══ -->
  <SolidColorBrush x:Key="BgDeepBrush"      Color="#FF090E16"/>
  <SolidColorBrush x:Key="BgPanelBrush"     Color="#FF0D1521"/>
  <SolidColorBrush x:Key="BgCardBrush"      Color="#FF111D2E"/>
  <SolidColorBrush x:Key="AccentBlueBrush"  Color="#FF2B7FFF"/>
  <SolidColorBrush x:Key="AccentGreenBrush" Color="#FF00E676"/>
  <SolidColorBrush x:Key="AccentAmberBrush" Color="#FFFFC107"/>
  <SolidColorBrush x:Key="AccentRedBrush"   Color="#FFFF3D3D"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFDCE8FF"/>
  <SolidColorBrush x:Key="TextDimBrush"     Color="#FF607898"/>
  <SolidColorBrush x:Key="BorderBrush2"     Color="#FF1C2E45"/>

  <!-- ══ BUTTON BASE ══ -->
  <Style x:Key="BtnBase" TargetType="Button">
    <Setter Property="Cursor"          Value="Hand"/>
    <Setter Property="FontFamily"      Value="Microsoft YaHei"/>
    <Setter Property="FontSize"        Value="12"/>
    <Setter Property="Padding"         Value="10,5"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.30"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="BtnBlue" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Background"  Value="#FF1A5FB4"/>
    <Setter Property="BorderBrush" Value="#FF2B7FFF"/>
    <Setter Property="Foreground"  Value="#FFDCE8FF"/>
  </Style>
  <Style x:Key="BtnGreen" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Background"  Value="#FF0D6B3A"/>
    <Setter Property="BorderBrush" Value="#FF00E676"/>
    <Setter Property="Foreground"  Value="#FFDCE8FF"/>
  </Style>
  <Style x:Key="BtnAmber" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Background"  Value="#FF6B4D00"/>
    <Setter Property="BorderBrush" Value="#FFFFC107"/>
    <Setter Property="Foreground"  Value="#FFFFDCA8"/>
  </Style>
  <Style x:Key="BtnRed" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Background"  Value="#FF6B1010"/>
    <Setter Property="BorderBrush" Value="#FFFF3D3D"/>
    <Setter Property="Foreground"  Value="#FFFFC5C5"/>
  </Style>
  <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnBase}">
    <Setter Property="Background"  Value="Transparent"/>
    <Setter Property="BorderBrush" Value="#FF1C2E45"/>
    <Setter Property="Foreground"  Value="#FF8AAAC8"/>
  </Style>

  <!-- ══ PANEL / TEXT ══ -->
  <Style x:Key="PanelCard" TargetType="Border">
    <Setter Property="Background"      Value="{StaticResource BgCardBrush}"/>
    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush2}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius"    Value="6"/>
    <Setter Property="Padding"         Value="12"/>
  </Style>

  <Style x:Key="SectionHeader" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
    <Setter Property="FontSize"   Value="10"/>
    <Setter Property="FontFamily" Value="Consolas"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Margin"     Value="0,0,0,6"/>
  </Style>

  <Style x:Key="ValueText" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Microsoft YaHei"/>
    <Setter Property="FontSize"   Value="13"/>
  </Style>

  <Style x:Key="HudNumber" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
    <Setter Property="FontFamily" Value="Consolas"/>
    <Setter Property="FontSize"   Value="16"/>
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>

  <!-- ══ TEXTBOX ══ -->
  <Style TargetType="TextBox">
    <Setter Property="Background"      Value="#FF0A1520"/>
    <Setter Property="Foreground"      Value="#FFDCE8FF"/>
    <Setter Property="BorderBrush"     Value="#FF1C2E45"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="6,4"/>
    <Setter Property="CaretBrush"      Value="#FF2B7FFF"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4"
                  Padding="{TemplateBinding Padding}">
            <ScrollViewer x:Name="PART_ContentHost"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="PasswordBox">
    <Setter Property="Background"      Value="#FF0A1520"/>
    <Setter Property="Foreground"      Value="#FFDCE8FF"/>
    <Setter Property="BorderBrush"     Value="#FF1C2E45"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding"         Value="6,4"/>
  </Style>

  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Width"      Value="5"/>
    <Setter Property="MinWidth"   Value="5"/>
  </Style>

</ResourceDictionary>
